# Ejemplo opcional: GitHub Actions que solo invoca Cursor si existe CURSOR_API_KEY.
# Copiar a .github/workflows/ y renombrar a .yml cuando tengas URL/API documentada.
# Si la secret no existe, el job sigue y solo corre tests estándar.

name: ci-optional-cursor
on:
  push:
    branches: [main]

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: npm
          cache-dependency-path: v0-editorial-control-station/package-lock.json
      - name: Install panel deps
        working-directory: v0-editorial-control-station
        run: npm ci
      - name: Lint / test (ejemplo)
        working-directory: v0-editorial-control-station
        run: npm run lint --if-present && npm run build --if-present
      # Paso opcional: llamada HTTP a Cloud Agents API (documentación oficial).
      # NO commitear API keys. Crear secret CURSOR_API_KEY en el repo.
      - name: Opcional — disparar agente Cursor
        if: env.CURSOR_API_KEY != ''
        env:
          CURSOR_API_KEY: ${{ secrets.CURSOR_API_KEY }}
        run: |
          echo "Aquí iría curl/fetch al endpoint documentado en cursor.com/docs"
          echo "Solo si Cursor sigue siendo parte del stack."
